# 运行期可被「设置页」覆盖；此处仅作首次启动默认
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_CHAT_MODEL=deepseek-v4-flash
LLM_EMBED_MODEL=deepseek-v4-flash

# 个人版默认：留空 → SQLite（data/kongku.db），无需 Docker
DATABASE_URL=

# 本机开发 CORS（Electron / Vite）
API_CORS_ORIGINS=http://localhost:41779,http://127.0.0.1:41779

# 可选：自备 Postgres 时再填写，例如：
# DATABASE_URL=postgresql+asyncpg://user:pass@127.0.0.1:5432/kongku

# —— 端口约定 ——
# API: 18765  |  Vite: 41779
