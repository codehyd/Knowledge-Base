# 运行期可被「设置页」覆盖；此处仅作首次启动默认
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_CHAT_MODEL=deepseek-v4-flash
LLM_EMBED_MODEL=deepseek-v4-flash

POSTGRES_USER=kongku
POSTGRES_PASSWORD=kongku
POSTGRES_DB=kongku
# 本地桌面 / 开发默认可不设：将使用 SQLite（data/kongku.db）
# 也可用设置页切换；Compose 全量部署再设 Postgres，例如：
# DATABASE_URL=postgresql+asyncpg://kongku:kongku@db:5432/kongku
# 本机连 Docker 库：postgresql+asyncpg://kongku:kongku@127.0.0.1:55432/kongku
DATABASE_URL=

# 本机开发时可改；Compose 内 web 通过 /api 反代
API_CORS_ORIGINS=http://localhost:41779,http://127.0.0.1:41779,http://localhost:18080

# —— Docker 加速 ——
# 默认 DaoCloud 代理；海外可清空：DOCKER_HUB_PROXY=
DOCKER_HUB_PROXY=docker.m.daocloud.io
# 可选：强制指定数据库镜像。开发加速可写本机已有的：
# POSTGRES_IMAGE=postgres:16-alpine
# POSTGRES_IMAGE=docker.m.daocloud.io/pgvector/pgvector:pg16

# —— 端口约定（不常见，减少冲突）——
# DB 宿主机: 55432  |  API: 18765  |  Vite: 41779  |  Compose Web: 18080
